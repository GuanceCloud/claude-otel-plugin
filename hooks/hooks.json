{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--quiet", "--script", "${CLAUDE_PLUGIN_ROOT}/hooks/claude_otel_hook.py"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--quiet", "--script", "${CLAUDE_PLUGIN_ROOT}/hooks/claude_otel_hook.py"]
          }
        ]
      }
    ]
  }
}
